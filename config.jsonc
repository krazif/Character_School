// ─── Character School Configuration ───────────────────────────
// JSONC format — comments are allowed (// and /* */
// This file is managed by the Settings page; you can also edit it manually.
//
{
  // Server settings
  "server": {
    "host": "0.0.0.0",
    "port": 7862
  },

  // ── Chat endpoint — drives the character's responses ──
  "chat": {
    "base_url": "https://nano-gpt.com/api/v1",
    "api_key": null,
    "model": "Gemma-4-31B-GarnetV2",
    "temperature": 1.0,
    "max_tokens": 2000
  },

  // ── Analysis endpoint — checks responses & generates fix suggestions ──
  "analysis": {
    "base_url": "https://openrouter.ai/api/v1",
    "api_key": null,
    "model": "deepseek/deepseek-v4-flash",
    "temperature": 0.1,
    "max_tokens": 1500
  },

  // Paths — can be absolute or relative to the app directory
  "paths": {
    "characters_dir": null, // null = defaults to ./characters inside app dir
    "personas_dir": null  // null = defaults to ./personas inside app dir
  }
}
